{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": false,
    "declaration": true,
    "rootDir": "./src",
    "outDir": "dist",
    "importHelpers": false,
    "strict": true,
    "esModuleInterop": true,
    "typeRoots": ["types", "node_modules/@types"],
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
